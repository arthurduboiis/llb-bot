# Token de l'application Discord (Developer Portal > Bot > Reset Token)
DISCORD_TOKEN=

# Client ID de l'application (Developer Portal > General Information > Application ID)
CLIENT_ID=

# ID du serveur Discord (clic droit sur le serveur > Copier l'ID, mode développeur requis)
GUILD_ID=

# ID du rôle "Officier" autorisé à gérer la banque, valider les retraits, faire les payouts
OFFICER_ROLE_ID=

# ID du salon "banque" où sera affiché le dashboard et où les retraits seront traités
BANK_CHANNEL_ID=

# ID de la catégorie où seront créés les channels temporaires de payout (laisser vide pour auto-création)
PAYOUT_CATEGORY_ID=

# Connexion à la base de données PostgreSQL hébergée sur Supabase.
# Où la trouver : Supabase > ton projet > bouton "Connect" (en haut) > onglet "Session pooler".
# ⚠️ Prends bien le "Session pooler" (port 5432), pas la "Direct connection" (qui ne marche
# pas sur Render, pas d'IPv6) ni le "Transaction pooler" port 6543 (moins compatible avec nos requêtes).
# Remplace [YOUR-PASSWORD] par le mot de passe de la base (Project Settings > Database > Database password).
# Format : postgresql://postgres.xxxxxxxxxxxx:[YOUR-PASSWORD]@aws-0-xx-xxxx-1.pooler.supabase.com:5432/postgres
DATABASE_URL=
